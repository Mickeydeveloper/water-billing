# Environment variables configuration
# Copy this to .env and fill with your actual values
# DO NOT commit your actual .env file to version control

# ================== SERVER CONFIG ==================
NODE_ENV=production
PORT=3000
SESSION_SECRET=your-session-secret-key-change-this

# ================== DATABASE ==================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/water-billing?retryWrites=true&w=majority

# ================== GOOGLE OAUTH 2.0 ==================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ================== JWT & SECURITY ==================
JWT_SECRET=your-very-secure-jwt-key-with-random-characters
JWT_EXPIRY=7d

# ================== ADMIN CONFIG ==================
ADMIN_EMAILS=admin@example.com,admin2@example.com

# ================== API RATE LIMITING ==================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================== CACHE CONFIG ==================
CACHE_ENABLED=true
CACHE_DURATION_MS=300000

# ================== LOG LEVEL ==================
LOG_LEVEL=info

