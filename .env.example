# Example environment variables (DO NOT COMMIT your real .env)
# Copy this to .env and fill values

# JWT secret used to sign session tokens
JWT_SECRET=your-very-secret-jwt-key

# Google OAuth 2.0 Client ID (public) and Client Secret (private)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Server port
PORT=10000

# Environment
NODE_ENV=development
